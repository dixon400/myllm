# Copy this to .env and fill in real values
#
#   cp .env.example .env
#
# IMPORTANT: Never commit .env (it is gitignored).

# --- LiteLLM auth (Open WebUI will use this to talk to LiteLLM) ---
LITELLM_MASTER_KEY=sk-change-me-to-a-long-random-string

# --- Postgres (used by litellm-db + DATABASE_URL) ---
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me

# For Docker Compose networking, LiteLLM connects to Postgres via the service name: litellm-db
DATABASE_URL=postgresql://litellm:change-me@litellm-db:5432/litellm

# --- Provider keys (set only what you actually use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Ollama Cloud (hosted), if you use it ---
# Make sure this ends with /v1
OLLAMA_CLOUD_API_BASE=https://your-ollama-host.example.com/v1
OLLAMA_CLOUD_API_KEY=
